# 海钓通 环境变量（模板）
# 复制为 .env 并填入实际值。.env 已在 .gitignore 中

# 微信小程序
MINIPROGRAM_APPID=wx2c553cb44c3b5a4f

# OpenProject
OPENPROJECT_URL=http://127.0.0.1:8080
OPENPROJECT_API_KEY=your_api_key_here

# 和风天气
HEFENG_WEATHER_KEY=your_key_here

# 高德地图
AMAP_KEY=your_key_here

# Sentry (可选)
SENTRY_DSN=your_dsn_here
