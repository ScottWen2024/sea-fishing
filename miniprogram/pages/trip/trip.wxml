<view class="page">
  <view style="display:grid;grid-template-columns:1fr 1fr;gap:16rpx;margin-bottom:24rpx;padding:0 20rpx;">
    <view class="card" style="text-align:center;padding:24rpx;" bindtap="showChains">
      <text style="font-size:40rpx;">✋</text><view style="font-size:26rpx;font-weight:500;margin-top:8rpx;">拼船接龙</view>
    </view>
    <view class="card" style="text-align:center;padding:24rpx;" bindtap="showCaptains">
      <text style="font-size:40rpx;">🔍</text><view style="font-size:26rpx;font-weight:500;margin-top:8rpx;">找船长/导钓</view>
    </view>
  </view>

  <view style="padding:0 20rpx;">
    <view style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx;">
      <text style="font-size:30rpx;font-weight:600;">✋ 拼船接龙</text>
      <button class="btn btn-primary btn-sm" bindtap="showCreateChain" style="width:auto;padding:10rpx 24rpx;">+ 发起</button>
    </view>
    <block wx:for="{{chains}}" wx:key="id">
      <view class="card" style="margin-bottom:16rpx;">
        <view style="display:flex;justify-content:space-between;">
          <text style="font-weight:600;">{{item.creatorName}} 的拼船</text>
          <text style="font-size:22rpx;padding:4rpx 12rpx;border-radius:16rpx;{{item.status==='full'?'background:#FFFBEB;color:#92400E;':'background:#ECFDF5;color:#065F46;'}}">{{item.status==='full'?'已满':'拼船中'}}</text>
        </view>
        <view style="font-size:24rpx;color:var(--text-secondary);margin-top:8rpx;">📍 {{item.port}} · 📅 {{item.date}} · 🐟 {{item.targetFish}}</view>
        <view style="display:flex;align-items:center;gap:12rpx;margin-top:12rpx;">
          <view style="flex:1;height:10rpx;background:#E5E7EB;border-radius:5rpx;"><view style="height:100%;background:#10B981;border-radius:5rpx;width:{{item.joined/item.maxPeople*100}}%;"></view></view>
          <text style="font-size:22rpx;color:var(--text-secondary);">{{item.joined}}/{{item.maxPeople}}人</text>
        </view>
        <button wx:if="{{item.status!=='full'}}" class="btn btn-outline btn-sm" bindtap="joinChain" data-id="{{item.id}}" style="margin-top:12rpx;width:100%;">✋ 我要接龙</button>
      </view>
    </block>
    <view wx:if="{{chains.length===0}}" class="empty"><view class="empty-text">暂无拼船接龙</view></view>
  </view>

  <view style="padding:0 20rpx;margin-top:32rpx;">
    <view style="font-size:30rpx;font-weight:600;margin-bottom:12rpx;">🔍 找船长/导钓</view>
    <view style="display:flex;gap:8rpx;margin-bottom:12rpx;">
      <button class="btn {{subMode==='boat'?'btn-primary':'btn-outline'}} btn-sm" bindtap="switchSubMode" data-mode="boat" style="flex:1;">🚤 拼船</button>
      <button class="btn {{subMode==='guide'?'btn-primary':'btn-outline'}} btn-sm" bindtap="switchSubMode" data-mode="guide" style="flex:1;">🎓 导钓</button>
    </view>
    <block wx:for="{{filteredCaptains}}" wx:key="id">
      <view class="card" style="margin-bottom:16rpx;">
        <view style="display:flex;gap:16rpx;align-items:center;">
          <text style="font-size:44rpx;">{{item.avatar}}</text>
          <view style="flex:1;">
            <text style="font-weight:600;font-size:30rpx;">{{item.name}}</text><text style="font-size:22rpx;color:var(--warning);margin-left:8rpx;">⭐ {{item.rating}}</text>
            <view style="font-size:24rpx;color:var(--text-secondary);">{{item.boatName}} · {{item.boatType}}</view>
            <view style="font-size:22rpx;color:var(--text-light);">📍{{item.port}} · {{item.completedOrders}}次出海</view>
          </view>
        </view>
        <view style="margin-top:8rpx;">
          <text class="tag tag-cert" wx:if="{{item.cert}}">✅ 认证</text>
          <text class="tag tag-fish">🐟 {{item.fishTarget}}</text>
          <text class="tag tag-guide" wx:if="{{item.guideEnabled}}">🎓 可导钓</text>
        </view>
      </view>
    </block>
  </view>

  <view style="padding:0 20rpx;margin-top:32rpx;">
    <view style="font-size:30rpx;font-weight:600;margin-bottom:12rpx;">📋 我的预约</view>
    <block wx:for="{{bookings}}" wx:key="id">
      <view class="card" style="margin-bottom:12rpx;">
        <view style="display:flex;justify-content:space-between;">
          <view><text style="font-weight:500;">{{item.captainName}}</text>
            <view style="font-size:24rpx;color:var(--text-secondary);">{{item.date}} · {{item.slot}} · {{item.people}}人 · ¥{{item.price}}</view>
          </view>
          <text style="font-size:22rpx;padding:6rpx 16rpx;border-radius:20rpx;{{item.status==='pending'?'background:#FFFBEB;color:#92400E;':''}}{{item.status==='confirmed'?'background:#ECFDF5;color:#065F46;':''}}{{item.status==='completed'?'background:#F3F4F6;color:#6B7280;':''}}">{{item.status==='pending'?'待确认':item.status==='confirmed'?'已确认':'已完成'}}</text>
        </view>
      </view>
    </block>
    <view wx:if="{{bookings.length===0}}" class="empty"><view class="empty-text">暂无预约</view></view>
  </view>
</view>

<view wx:if="{{showChainForm}}" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:200;display:flex;align-items:flex-end;">
  <view style="background:white;width:100%;border-radius:32rpx 32rpx 0 0;padding:32rpx;">
    <view style="font-size:34rpx;font-weight:600;text-align:center;margin-bottom:24rpx;">✋ 发起拼船</view>
    <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:12rpx;font-size:28rpx;" placeholder="日期 如:2026-06-01" value="{{newChain.date}}" bindinput="onChainInput" data-field="date"/>
    <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:12rpx;font-size:28rpx;" placeholder="港口" value="{{newChain.port}}" bindinput="onChainInput" data-field="port"/>
    <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:12rpx;font-size:28rpx;" placeholder="目标鱼种" value="{{newChain.fish}}" bindinput="onChainInput" data-field="fish"/>
    <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:12rpx;font-size:28rpx;" placeholder="需要人数" value="{{newChain.maxPeople}}" bindinput="onChainInput" data-field="maxPeople"/>
    <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:12rpx;font-size:28rpx;" placeholder="你的称呼" value="{{newChain.name}}" bindinput="onChainInput" data-field="name"/>
    <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:16rpx;font-size:28rpx;" placeholder="联系方式" value="{{newChain.contact}}" bindinput="onChainInput" data-field="contact"/>
    <view style="display:flex;gap:12rpx;">
      <button class="btn btn-primary" bindtap="createChain" style="flex:1;">✅ 发起</button>
      <button class="btn btn-outline" bindtap="hideCreateChain" style="flex:1;">取消</button>
    </view>
  </view>
</view>
