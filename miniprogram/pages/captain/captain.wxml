<view class="page">
  <view style="display:flex;background:white;border-radius:12rpx;overflow:hidden;margin-bottom:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,0.06);">
    <view wx:for="{{tabs}}" wx:key="*this" data-tab="{{item}}" bindtap="switchCTab" style="flex:1;text-align:center;padding:20rpx;font-size:26rpx;{{ctab===item?'background:var(--primary);color:white;font-weight:600;':'color:var(--text-secondary);'}}">{{item}}</view>
  </view>

  <!-- 资料 -->
  <view wx:if="{{ctab==='👤 资料'}}" style="padding:0 20rpx;">
    <view class="card">
      <view class="card-title">👤 我的资料</view>
      <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:16rpx;font-size:28rpx;" placeholder="姓名" value="{{profile.name}}" bindinput="onProfileInput" data-field="name"/>
      <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:16rpx;font-size:28rpx;" placeholder="手机号" value="{{profile.phone}}" bindinput="onProfileInput" data-field="phone"/>
      <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:16rpx;font-size:28rpx;" placeholder="船名" value="{{profile.boatName}}" bindinput="onProfileInput" data-field="boatName"/>
      <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:16rpx;font-size:28rpx;" placeholder="船型 如:12米艇 6人" value="{{profile.boatType}}" bindinput="onProfileInput" data-field="boatType"/>
      <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:16rpx;font-size:28rpx;" placeholder="服务港口" value="{{profile.port}}" bindinput="onProfileInput" data-field="port"/>
      <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:16rpx;font-size:28rpx;" placeholder="资质证书 如:持证15年" value="{{profile.cert}}" bindinput="onProfileInput" data-field="cert"/>
      <button class="btn btn-primary" bindtap="saveProfile">💾 保存资料</button>
    </view>
  </view>

  <!-- 排期 -->
  <view wx:if="{{ctab==='📅 排期'}}" style="padding:0 20rpx;">
    <view class="card">
      <view class="card-title">📅 发布排期</view>
      <input style="border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;margin-bottom:12rpx;font-size:28rpx;" placeholder="日期 如:2026-06-01" value="{{sched.date}}"/>
      <view style="display:flex;gap:12rpx;margin-bottom:12rpx;">
        <input style="flex:1;border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;font-size:28rpx;" placeholder="可接人数" value="{{sched.capacity}}"/>
        <input style="flex:1;border:2rpx solid var(--border);border-radius:8rpx;padding:16rpx;font-size:28rpx;" placeholder="费用 元/人" value="{{sched.price}}"/>
      </view>
      <button class="btn btn-primary" bindtap="publishSchedule">📢 发布排期</button>
    </view>
    <view class="card" wx:if="{{schedules.length>0}}">
      <view class="card-title">已发布排期</view>
      <view wx:for="{{schedules}}" wx:key="date" style="display:flex;justify-content:space-between;padding:12rpx 0;border-bottom:2rpx solid var(--border);font-size:26rpx;">
        <view>{{item.date}} · {{item.slot||'全日'}} · ¥{{item.price}}/人</view>
        <text style="color:var(--text-light);">{{item.remaining}}/{{item.capacity}}位</text>
      </view>
    </view>
  </view>

  <!-- 预约 -->
  <view wx:if="{{ctab==='📨 预约'}}" style="padding:0 20rpx;">
    <view wx:for="{{cBookings}}" wx:key="id" class="card" style="margin-bottom:12rpx;">
      <view style="display:flex;justify-content:space-between;">
        <view><text style="font-weight:500;">{{item.userName}}</text>
          <view style="font-size:24rpx;color:var(--text-secondary);">{{item.date}} · {{item.slot}} · {{item.people}}人 · ¥{{item.price}}</view>
          <view style="font-size:22rpx;color:var(--text-light);">📞 {{item.userContact}}</view>
        </view>
        <view>
          <text style="font-size:22rpx;padding:6rpx 16rpx;border-radius:20rpx;{{item.status==='pending'?'background:#FFFBEB;color:#92400E;':''}}{{item.status==='confirmed'?'background:#ECFDF5;color:#065F46;':''}}{{item.status==='completed'?'background:#F3F4F6;color:#6B7280;':''}}">{{item.status==='pending'?'待确认':item.status==='confirmed'?'已确认':'已完成'}}</text>
          <button wx:if="{{item.status==='pending'}}" class="btn btn-primary btn-sm" bindtap="confirmBooking" data-id="{{item.id}}" style="margin-top:8rpx;">确认</button>
          <button wx:if="{{item.status==='confirmed'}}" class="btn btn-sm" style="margin-top:8rpx;background:var(--success);color:white;" bindtap="completeBooking" data-id="{{item.id}}">完成</button>
        </view>
      </view>
    </view>
    <view wx:if="{{cBookings.length===0}}" class="empty"><view class="empty-text">暂无预约</view></view>
  </view>

  <!-- 统计 -->
  <view wx:if="{{ctab==='📊 统计'}}" style="padding:0 20rpx;">
    <view class="stats-grid">
      <view class="stat-card"><view class="stat-val">{{stats.orders}}</view><view class="stat-lbl">本月订单</view></view>
      <view class="stat-card"><view class="stat-val">¥{{stats.revenue}}</view><view class="stat-lbl">本月收入</view></view>
      <view class="stat-card"><view class="stat-val">⭐ {{stats.rating}}</view><view class="stat-lbl">平均评分</view></view>
    </view>
  </view>
</view>
