<view class="page"><view wx:for="{{items}}" wx:key="id" class="card" style="margin-bottom:12rpx;"><view class="m-name">{{item.fishName}} {{item.weight}}</view><view class="m-date">{{item.date}} | {{item.port}}</view><view class="m-price"><text class="price-tag">{{item.price}}</text> {{item.takeMethod}}</view><button class="btn btn-outline btn-sm" bindtap="contact" data-id="{{item.id}}" style="margin-top:12rpx;">Contact Seller</button></view><view wx:if="{{items.length==0}}" class="empty"><view class="empty-text">No items for sale</view></view></view>