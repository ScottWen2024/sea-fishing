{
  "scripts": {
    "lint": "eslint pages/ --ext .js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix --max-warnings 5",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.wxml": [
      "prettier --write"
    ],
    "*.wxss": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
