{
  "scripts": {
    "lint": "eslint pages/ --ext .js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "eslint": "^8.57.1",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "secretlint": "^13.0.2"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix --max-warnings 5",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.wxml": [
      "prettier --write"
    ],
    "*.wxss": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "sentry-miniapp": "^1.9.0"
  }
}
