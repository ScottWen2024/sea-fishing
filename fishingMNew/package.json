{
  "scripts": {
    "lint": "eslint pages/ --ext .js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "prettier": "^3.0.0",
    "lint-staged": "^15.0.0",
    "husky": "^9.0.0"
  },
  "lint-staged": {
    "*.js": ["eslint --fix --max-warnings 5", "prettier --write"],
    "*.json": ["prettier --write"],
    "*.wxml": ["prettier --write"],
    "*.wxss": ["prettier --write"],
    "*.md": ["prettier --write"]
  }
}
