.tab-row{display:flex;gap:8rpx;margin-bottom:16rpx;}.tab{flex:1;text-align:center;padding:16rpx;border-radius:12rpx;font-size:26rpx;border:2rpx solid var(--border);color:var(--text-secondary);}.tab.active{background:var(--primary);color:white;border-color:var(--primary);}.guide-tip{font-size:26rpx;line-height:1.8;}.warn{font-weight:600;color:var(--danger);}.danger{color:var(--danger);margin-top:12rpx;}.hd{font-weight:600;margin-top:12rpx;}.green-box{background:#ECFDF5;padding:12rpx;border-radius:8rpx;margin-top:12rpx;color:#065F46;font-weight:600;}