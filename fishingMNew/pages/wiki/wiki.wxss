.wiki-item{display:flex;align-items:center;gap:16rpx;margin-bottom:8rpx;}.wiki-icon{font-size:44rpx;}.wiki-info{flex:1;}.wiki-name{font-weight:600;}.wiki-sub{font-size:22rpx;color:var(--text-light);}.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:200;display:flex;align-items:flex-end;}.modal-body{background:white;width:100%;border-radius:32rpx 32rpx 0 0;padding:32rpx;max-height:80vh;overflow-y:auto;}.big-icon{text-align:center;font-size:64rpx;display:block;}.modal-title{text-align:center;font-size:36rpx;font-weight:700;margin:8rpx 0;}.modal-sub{text-align:center;font-size:24rpx;color:var(--text-light);margin-bottom:16rpx;}.info-grid{background:var(--bg);padding:20rpx;border-radius:8rpx;margin-bottom:12rpx;display:grid;grid-template-columns:1fr 1fr;gap:8rpx;font-size:24rpx;color:var(--text-secondary);}.info-line{font-size:24rpx;color:var(--text-secondary);margin:8rpx 0;}.desc{font-size:24rpx;color:var(--text-light);margin-bottom:16rpx;}