.chip-row{white-space:nowrap;margin-bottom:16rpx;}.chip{display:inline-block;padding:10rpx 20rpx;border-radius:20rpx;font-size:24rpx;margin-right:8rpx;border:2rpx solid var(--border);color:var(--text-secondary);}.must{font-weight:600;color:#EF4444;margin:12rpx 0 8rpx;}.rec{font-weight:600;color:#F59E0B;margin:12rpx 0 8rpx;}.opt{font-weight:600;color:#9CA3AF;margin:12rpx 0 8rpx;}.item{padding:8rpx 0;font-size:26rpx;}